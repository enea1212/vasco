rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: orice utilizator autentificat poate citi, doar proprietarul poate scrie profilul său
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;

      // Friends subcollection: doar proprietarul poate citi, scrierile sunt gestionate de Cloud Functions
      match /friends/{friendId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      // Location groups: proprietarul poate citi/scrie grupurile sale
      match /location_groups/{groupId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        match /members/{memberId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }
    }

    // User locations: orice utilizator autentificat poate citi, doar proprietarul poate scrie/șterge
    match /user_locations/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Friend requests: utilizatorii pot citi propriile cereri, scrierile sunt gestionate de Cloud Functions
    match /friend_requests/{requestId} {
      allow read: if request.auth != null &&
                  (resource.data.fromUserId == request.auth.uid ||
                   resource.data.toUserId == request.auth.uid);
      allow write: if false;
    }

    // Posts: autentificații pot citi, proprietarul poate crea/edita
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
                    request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null &&
                    resource.data.userId == request.auth.uid &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['description']);
      allow delete: if false;

      match /likes/{userId} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // Location photos: queries libere, citire directă protejată de privacy
    match /location_photos/{photoId} {
      allow list: if request.auth != null;
      allow get: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        !get(/databases/$(database)/documents/users/$(resource.data.userId)).data.get('isPrivate', false) ||
        exists(/databases/$(database)/documents/users/$(resource.data.userId)/friends/$(request.auth.uid))
      );
      allow create: if request.auth != null &&
                    request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null &&
                    resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null &&
                    resource.data.userId == request.auth.uid;

      match /likes/{userId} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // Swipes: scrise doar de Cloud Functions (admin SDK), citite doar de proprietar
    match /swipes/{swipeId} {
      allow read: if request.auth != null &&
                  resource.data.fromUserId == request.auth.uid;
      allow write: if false;
    }

    // Matches: doar participanții pot citi, scrierile sunt gestionate de Cloud Functions
    match /matches/{matchId} {
      allow read: if request.auth != null &&
                  request.auth.uid in resource.data.users;
      allow write: if false;
    }

    // Conversations: doar participanții pot citi/scrie
    match /conversations/{conversationId} {
      allow read: if request.auth != null
                  && (resource == null || request.auth.uid in resource.data.participantIds);
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participantIds
                    && request.resource.data.participantIds.size() >= 2;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participantIds
                    && request.resource.data.participantIds == resource.data.participantIds;
      allow delete: if false;

      // Messages: participanții pot citi, doar expeditorul poate crea
      match /messages/{messageId} {
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow create: if request.auth != null
                      && request.resource.data.senderId == request.auth.uid
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow update: if false;
        allow delete: if false;
      }
    }

  }
}
